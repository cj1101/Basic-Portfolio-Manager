# Required: Alpha Vantage primary market-data provider. App refuses to start without it.
ALPHA_VANTAGE_API_KEY=

# Optional: FRED API key for the live 3-month T-bill rate. If unset, a static fallback is used.
FRED_API_KEY=

# ----------------------------------------------------------------------------
# Chat LLM (OpenRouter)
# ----------------------------------------------------------------------------
# Required to enable the LLM fallback in /api/chat. When unset, the /chat
# endpoint still works — it just stays in rule-based mode. The frontend greys
# out the "LLM" toggle in that case.
OPENROUTER_API_KEY=

# Default OpenRouter model slug. Users can override this per-session from the
# frontend Settings panel. See https://openrouter.ai/models for the full list.
OPENROUTER_MODEL=google/gemma-4-31b-it

# OpenRouter's OpenAI-compatible base URL. Override only if you are self-hosting
# a compatible gateway.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Attribution headers sent with every OpenRouter request. Recommended by
# OpenRouter so your requests appear correctly on https://openrouter.ai/activity.
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Portfolio Manager

# ----------------------------------------------------------------------------
# Optional overrides
# ----------------------------------------------------------------------------
PORT=8000
CACHE_DB_PATH=backend/.cache/market.db
CORS_ORIGINS=http://localhost:5173

# Fallback behaviour. Set USE_MOCK_FALLBACK=true to serve deterministic synthetic
# bars when BOTH Alpha Vantage and Yahoo are unavailable. Off by default so
# production never silently returns fake data.
USE_MOCK_FALLBACK=false

# Integration-test gate. Set to 1 to run live-API tests (consumes Alpha Vantage
# daily quota and talks to yfinance / FRED / OpenRouter).
RUN_LIVE_TESTS=0
