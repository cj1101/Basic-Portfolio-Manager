# Required: Alpha Vantage primary market-data provider. App refuses to start without it.
ALPHA_VANTAGE_API_KEY=AM4L9RSB3ME2HN3H

# Optional: FRED API key for the live 3-month T-bill rate. If unset, a static fallback is used.
FRED_API_KEY=303f975c02ad4b5cc56696edace9fabd

# Optional: enables LLM fallback in /chat (unused in Phase 1B).
OPENAI_API_KEY=

# Optional overrides
PORT=8000
CACHE_DB_PATH=backend/.cache/market.db
CORS_ORIGINS=http://localhost:5173

# Fallback behaviour. Set USE_MOCK_FALLBACK=true to serve deterministic synthetic
# bars when BOTH Alpha Vantage and Yahoo are unavailable. Off by default so
# production never silently returns fake data.
USE_MOCK_FALLBACK=false

# Integration-test gate. Set to 1 to run live-API tests (consumes Alpha Vantage
# daily quota and talks to yfinance / FRED).
RUN_LIVE_TESTS=0
