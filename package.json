{
  "name": "portfolio-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Portfolio Manager monorepo — Phase 1A Quant Engine",
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "dev": "python scripts/dev.py",
    "dev:all": "python scripts/dev.py",
    "dev:backend": "python scripts/dev.py --no-frontend",
    "dev:frontend": "python scripts/dev.py --no-backend",
    "bench": "python scripts/bench.py",
    "test:e2e": "pnpm --dir frontend run test:e2e",
    "test:e2e:install": "pnpm --dir frontend run test:e2e:install"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
